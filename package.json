{
  "name": "vitalcare-api",
  "version": "1.0.0",
  "description": "API do VitalCare - Sistema de agendamento de consultas médicas para saúde pública no Brasil",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "format": "prettier --write .",
    "docs": "jsdoc -c jsdoc.conf.json",
    "build": "echo 'Build completed'",
    "docker:build": "docker build -t vitalcare-api .",
    "docker:run": "docker run -p 3000:3000 vitalcare-api"
  },
  "keywords": [
    "healthcare",
    "medical",
    "appointments",
    "api",
    "nodejs",
    "express",
    "mvc",
    "brazil",
    "saude-publica",
    "vitalcare"
  ],
  "author": {
    "name": "VitalCare Team",
    "email": "contato@vitalcare.com.br",
    "url": "https://vitalcare.com.br"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vitalcare/vitalcare-api.git"
  },
  "bugs": {
    "url": "https://github.com/vitalcare/vitalcare-api/issues"
  },
  "homepage": "https://vitalcare.com.br",
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "joi": "^17.11.0",
    "dotenv": "^16.3.1",
    "compression": "^1.7.4",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "swagger-ui-express": "^5.0.0",
    "swagger-jsdoc": "^6.2.8"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.55.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.0",
    "prettier": "^3.1.1",
    "jsdoc": "^4.0.2",
    "@types/jest": "^29.5.8"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "**/*.js",
      "!node_modules/**",
      "!coverage/**",
      "!package.json",
      "!README.md"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ],
    "testMatch": [
      "**/tests/**/*.test.js",
      "**/__tests__/**/*.js"
    ]
  },
  "eslintConfig": {
    "extends": [
      "airbnb-base"
    ],
    "rules": {
      "no-console": "warn",
      "max-len": [
        "error",
        {
          "code": 120
        }
      ],
      "indent": [
        "error",
        2
      ]
    }
  },
  "prettier": {
    "semi": true,
    "trailingComma": "es5",
    "singleQuote": true,
    "printWidth": 120,
    "tabWidth": 2,
    "useTabs": false
  },
  "nodemonConfig": {
    "watch": [
      "./"
    ],
    "ext": "js,json",
    "ignore": [
      "node_modules/",
      "coverage/",
      "tests/"
    ],
    "env": {
      "NODE_ENV": "development"
    }
  }
}
